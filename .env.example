# IBM watsonx Orchestrate Configuration
# Copy this file to .env and fill in your values

WXO_BASE_URL=https://api.eu-gb.watson-orchestrate.cloud.ibm.com
WXO_API_KEY=your_ibm_cloud_api_key_here
WXO_INSTANCE_ID=your_instance_id_here
WXO_APP_ID=your_app_id_here

# Agent IDs (get from watsonx Orchestrate URL)
PLANNER_AGENT_ID=your_planner_agent_id_here
MARKET_AGENT_ID=your_market_agent_id_here
STRATEGY_AGENT_ID=your_strategy_agent_id_here
FINANCE_AGENT_ID=your_finance_agent_id_here
GTM_AGENT_ID=your_gtm_agent_id_here
PITCH_AGENT_ID=your_pitch_agent_id_here

PORT=5000
FLASK_DEBUG=false
DEMO_MODE=true
